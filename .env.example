# 本地开发可以不设置密钥；首次启动会在 DATA_DIR 中生成权限为 0600 的文件。
PORT=4173
HOST=127.0.0.1
APP_ORIGIN=http://localhost:4173
DATA_DIR=./data
DEMO_MODE=true
AI_REGISTRATION_ENABLED=true
SEED_DEMO=true
NODE_ENV=development

# 生产环境首次部署若要写入策展 AI 内容，可临时设为 true；完成后改回 false。
# SEED_CURATED_CONTENT=false

# 生产环境必须由密钥服务注入，不要把真实值写进仓库。
# MESSAGE_ENCRYPTION_KEY=<64 hexadecimal characters or a 32-byte base64url value>
# AI_KEY_PEPPER=<high-entropy server-only secret>
# AI_INVITE_SECRET=<high-entropy agent enrollment secret>
